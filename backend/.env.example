WIX_SCANNER_APP_NAME=Wix Scanner Backend
WIX_SCANNER_ENVIRONMENT=development
WIX_SCANNER_API_V1_PREFIX=/api
WIX_SCANNER_CORS_ORIGINS=["http://localhost:5173"]
WIX_SCANNER_BOOTSTRAP_SECRET=dev-bootstrap-secret-change-in-production
WIX_SCANNER_WIX_MOCK_MODE=true
WIX_SCANNER_CREDENTIAL_PROVIDER_MODE=env
# Required only when WIX_SCANNER_CREDENTIAL_PROVIDER_MODE=env.
WIX_SCANNER_WIX_API_TOKEN=
WIX_SCANNER_CREDENTIAL_DB_PATH=./data/credentials.db
WIX_SCANNER_SITE_EVENT_BINDING_DB_PATH=./data/site_event_bindings.db
WIX_SCANNER_RECONCILIATION_DB_PATH=./data/reconciliation.db
WIX_SCANNER_CREDENTIAL_ENCRYPTION_KEY=dev-credential-key-must-change
WIX_SCANNER_WIX_TIMEOUT_MS=2500
WIX_SCANNER_WIX_MAX_RETRIES=3
WIX_SCANNER_WIX_RETRY_BASE_MS=150
WIX_SCANNER_WIX_RETRY_MAX_MS=1500
WIX_SCANNER_REDIS_URL=redis://redis:6379/0
WIX_SCANNER_REDIS_KEY_PREFIX=wix-scanner
WIX_SCANNER_PENDING_MARKER_TTL_S=86400
WIX_SCANNER_MANIFEST_CACHE_TTL_S=86400
WIX_SCANNER_OFFLINE_QUEUE_MAX_ATTEMPTS=5
WIX_SCANNER_OFFLINE_QUEUE_WORKER_INTERVAL_S=2
WIX_SCANNER_WIX_WEBHOOK_SECRET=dev-webhook-secret
WIX_SCANNER_RELAY_AUTH_TOKEN=dev-relay-auth-token-change-in-production
WIX_SCANNER_RELAY_SIGNING_SECRET=dev-relay-signing-secret-change-in-production
WIX_SCANNER_RELAY_PROTOCOL_VERSION=2026-05-29
